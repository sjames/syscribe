@startuml PowerSystemIBD
skinparam component {
  BackgroundColor #f5f5fa
  BorderColor #3a3a4a
}

rectangle "PowerSystem" as s_boundary [[https://github.com/sjames/syscribe/blob/main/model/UAV/Power/PowerSystem.md]] {
  component "battery" as s_battery [[https://github.com/sjames/syscribe/blob/main/model/UAV/Power/PowerSystem/battery.md]]
  component "pdu" as s_pdu [[https://github.com/sjames/syscribe/blob/main/model/UAV/Power/PowerSystem/pdu.md]]
}

s_battery --> s_pdu : flow
s_pdu ..> s_boundary : binding

@enduml
