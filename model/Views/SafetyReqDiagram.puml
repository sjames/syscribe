@startuml SafetyReqDiagram
!include /home/sjames/playground/syscribe/.plantuml/sysml.iuml
hide empty members

class "UAV shall not cause injury to persons or property during any flight phase" as s_safe <<requirement>> [[https://github.com/sjames/syscribe/blob/main/model/Requirements/SafetyParentReq.md]]
class "Autonomous safe landing on battery-critical or link-loss event" as s_land <<requirement>> [[https://github.com/sjames/syscribe/blob/main/model/Requirements/SafeLandingReq.md]]
class "Flight controller shall detect single sensor failure within 50 ms" as s_fc <<requirement>> [[https://github.com/sjames/syscribe/blob/main/model/Requirements/FaultTolerantFCReq.md]]
class "Safety case review confirms UAV shall not cause injury across all flight phases" as s_review <<test case>> [[https://github.com/sjames/syscribe/blob/main/model/Verification/SafetyCaseReview.md]]
class "Autonomous landing descent rate ≤ 3 m/s on battery-critical trigger" as s_ltest <<test case>> [[https://github.com/sjames/syscribe/blob/main/model/Verification/SafeLandingTest.md]]
class "FC detects injected sensor failure within 50 ms on HIL bench" as s_fitest <<test case>> [[https://github.com/sjames/syscribe/blob/main/model/Verification/FCFaultInjectionTest.md]]
class "FlightController" as s_flightc <<part>> [[https://github.com/sjames/syscribe/blob/main/model/UAV/Avionics/FlightController.md]]

s_land ..> s_safe : derivedFrom
s_fc ..> s_safe : derivedFrom
s_review ..> s_safe : verifies
s_ltest ..> s_land : verifies
s_fitest ..> s_fc : verifies
s_flightc --> s_fc : satisfies

@enduml
